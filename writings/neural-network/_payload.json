20,"style":233},[210],[72,2022,587],{"className":2023},[237],[72,2025],{"className":2026,"style":233},[210],[72,2028,2030,2033,2036],{"className":2029},[106],[72,2031],{"className":2032,"style":1911},[110],[72,2034,1813],{"className":2035,"style":1915},[115,116],[72,2037,2039,2042,2101],{"className":2038},[115],[72,2040],{"className":2041},[489,637],[72,2043,2045],{"className":2044},[566],[72,2046,2048,2093],{"className":2047},[644,645],[72,2049,2051,2090],{"className":2050},[649],[72,2052,2054,2068,2076],{"className":2053,"style":1934},[653],[72,2055,2056,2059],{"style":992},[72,2057],{"className":2058,"style":662},[661],[72,2060,2062,2065],{"className":2061},[115],[72,2063,1821],{"className":2064,"style":1946},[115],[72,2066,136],{"className":2067},[115,116],[72,2069,2070,2073],{"style":722},[72,2071],{"className":2072,"style":662},[661],[72,2074],{"className":2075,"style":730},[729],[72,2077,2078,2081],{"style":1012},[72,2079],{"className":2080,"style":662},[661],[72,2082,2084,2087],{"className":2083},[115],[72,2085,1821],{"className":2086,"style":1946},[115],[72,2088,806],{"className":2089},[115,116],[72,2091,750],{"className":2092},[749],[72,2094,2096],{"className":2095},[649],[72,2097,2099],{"className":2098,"style":1031},[653],[72,2100],{},[72,2102],{"className":2103},[496,637],[24,2105,2107],{"id":2106},"_33-gradient-propagation-via-the-chain-rule","3.3 - Gradient Propagation via the Chain Rule",[10,2109,2110,2111,2114],{},"Using ",[14,2112,2113],{},"backpropagation",", the error is propagated backward through the network using the chain rule, adjusting each weight accordingly.",[19,2116,2118],{"id":2117},"_4-optimization-and-regularization","4 - Optimization and Regularization",[24,2120,2122],{"id":2121},"_41-optimization-algorithms-sgd-adam","4.1 - Optimization Algorithms (SGD, Adam)",[39,2124,2125,2131],{},[42,2126,2127,2130],{},[14,2128,2129],{},"Stochastic Gradient Descent (SGD)",": Updates weights after each sample.",[42,2132,2133,2136],{},[14,2134,2135],{},"Adam",": A more advanced optimizer that adapts learning rates per parameter.",[10,2138,2139],{},"The gradient of a function is the vector whose elements are its partial derivatives with respect to each parameter.So each element of the gradient tells us how the cost function would change if we applied a small change to that particular parameter – so we know what to tweak and by how much. To summarize, we can march towards the minimum by following these steps:",[275,2141],{"caption":2142,"label":2142,"src":2143},"Gradient Descent","/writings/neural-network/gradient-descent.png",[2145,2146,2147,2150,2153],"ol",{},[42,2148,2149],{},"Compute the gradient of our \"current location\" (calculate the gradient using our current parameter values).",[42,2151,2152],{},"Modify each parameter by an amount proportional to its gradient element and in the opposite direction of its gradient element. For example, if the partial derivative of our cost function with respect to B0 is positive but tiny and the partial derivative with respect to B1 is negative and large, then we want to decrease B0 by a tiny amount and increase B1 by a large amount to lower our cost function.",[42,2154,2155],{},"Recompute the gradient using our new tweaked parameter values and repeat the previous steps until we arrive at the minimum.",[24,2157,2159],{"id":2158},"_42-regularization-to-avoid-overfitting-dropout-l1l2","4.2 - Regularization to Avoid Overfitting (Dropout, L1/L2)",[10,2161,2162],{},"To prevent overfitting:",[39,2164,2165,2171],{},[42,2166,2167,2170],{},[14,2168,2169],{},"Dropout"," randomly disables neurons during training.",[42,2172,2173,2176],{},[14,2174,2175],{},"L1/L2 regularization"," penalizes large weights to encourage simpler models.",[19,2178,2180],{"id":2179},"_5-network-architectures","5 - Network Architectures",[10,2182,2183],{},"Multi-Layer Perceptron (MLP)\nA standard feedforward neural network with multiple layers.",[10,2185,2186],{},"Convolutional Neural Networks (CNN) for Images\nSpecialized for image processing using convolutional filters.",[10,2188,2189],{},"Recurrent Neural Networks (RNN, LSTM, GRU) for Sequences\nUseful for time series and natural language tasks.",[10,2191,2192],{},"Transformers for NLP and Vision\nState-of-the-art architecture for language understanding and vision tasks.",[19,2194,2196],{"id":2195},"_6-training-and-evaluation","6 - Training and Evaluation",[24,2198,2200],{"id":2199},"_61-data-splitting-traintest-split","6.1 - Data Splitting (Train/Test Split)",[10,2202,2203,2204,2207,2208,2211],{},"To evaluate performance, data is split into ",[14,2205,2206],{},"training"," and ",[14,2209,2210],{},"test"," sets.",[24,2213,2215],{"id":2214},"_62-evaluation-metrics-accuracy-precision-recall-rmse-r","6.2 - Evaluation Metrics (Accuracy, Precision, Recall, RMSE, R²)",[10,2217,2218],{},"Metrics depend on the task:",[39,2220,2221,2227],{},[42,2222,2223,2226],{},[14,2224,2225],{},"Accuracy, Precision, Recall"," for classification.",[42,2228,2229,2232],{},[14,2230,2231],{},"RMSE, R²"," for regression.",[24,2234,2236],{"id":2235},"_63-hyperparameter-tuning","6.3 - Hyperparameter Tuning",[10,2238,2239],{},"Choosing the right:",[39,2241,2242,2247,2252],{},[42,2243,2244],{},[14,2245,2246],{},"Learning rate",[42,2248,2249],{},[14,2250,2251],{},"Batch size",[42,2253,2254],{},[14,2255,2256],{},"Number of layers and neurons",[19,2258,2260],{"id":2259},"_7-example-a-neural-network-with-two-hidden-layers","7 - Example: A Neural Network with Two Hidden Layers",[10,2262,2263,2264,2267],{},"The following example demonstrates a simple ",[14,2265,2266],{},"multi-layer perceptron (MLP)"," with two hidden layers, trained to perform linear regression.",[2269,2270,2275],"pre",{"className":2271,"code":2272,"language":2273,"meta":2274,"style":2274},"language-python shiki shiki-themes github-dark","import numpy as np\nimport tensorflow as tf\nimport matplotlib.pyplot as plt\n\n# Generating data\nX = np.linspace(-1, 1, 100).reshape(-1, 1)\ny = 2 * X + 1 + 0.1 * np.random.randn(100, 1)  # y = 2x + 1 with noise\n\n# Defining the model\nmodel = tf.keras.Sequential([\n    tf.keras.layers.Dense(10, input_shape=(1,), activation='relu'),  # First hidden layer\n    tf.keras.layers.Dense(5, activation='relu'),  # Second hidden layer\n    tf.keras.layers.Dense(1, activation='linear')  # Output layer\n])\n\n# Compiling the model\nmodel.compile(optimizer='adam', loss='mse')\n\n# Training the model\nmodel.fit(X, y, epochs=200, verbose=0)\n\n# Predictions\npredictions = model.predict(X)\n\n# Visualizing results\nplt.scatter(X, y, label=\"Actual Data\")\nplt.plot(X, predictions, color='red', label=\"Model Predictions\")\nplt.legend()\nplt.show()\n","python","",[2276,2277,2278,2296,2309,2322,2329,2336,2377,2422,2427,2433,2444,2483,2504,2525,2531,2536,2542,2568,2573,2579,2604,2609,2615,2626,2631,2637,2653,2678,2684],"code",{"__ignoreMap":2274},[72,2279,2282,2286,2290,2293],{"class":2280,"line":2281},"line",1,[72,2283,2285],{"class":2284},"snl16","import",[72,2287,2289],{"class":2288},"s95oV"," numpy ",[72,2291,2292],{"class":2284},"as",[72,2294,2295],{"class":2288}," np\n",[72,2297,2299,2301,2304,2306],{"class":2280,"line":2298},2,[72,2300,2285],{"class":2284},[72,2302,2303],{"class":2288}," tensorflow ",[72,2305,2292],{"class":2284},[72,2307,2308],{"class":2288}," tf\n",[72,2310,2312,2314,2317,2319],{"class":2280,"line":2311},3,[72,2313,2285],{"class":2284},[72,2315,2316],{"class":2288}," matplotlib.pyplot ",[72,2318,2292],{"class":2284},[72,2320,2321],{"class":2288}," plt\n",[72,2323,2325],{"class":2280,"line":2324},4,[72,2326,2328],{"emptyLinePlaceholder":2327},true,"\n",[72,2330,2332],{"class":2280,"line":2331},5,[72,2333,2335],{"class":2334},"sAwPA","# Generating data\n",[72,2337,2339,2342,2344,2347,2350,2353,2356,2358,2360,2363,2366,2368,2370,2372,2374],{"class":2280,"line":2338},6,[72,2340,2341],{"class":2288},"X ",[72,2343,176],{"class":2284},[72,2345,2346],{"class":2288}," np.linspace(",[72,2348,2349],{"class":2